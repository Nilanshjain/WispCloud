# WispCloud backend environment template.
# Copy this file to .env and fill in real values. Never commit the .env.
# `dotenv-safe` will fail boot if any key listed below is missing from .env.

# --- Required: app refuses to boot without these ---
MONGODB_URI=
JWT_SECRET=
SESSION_SECRET=

# --- Optional: feature-gated, app boots without them but feature degrades ---
#
# PORT=5001                      # Defaults to 5001 if unset.
# NODE_ENV=development           # Set to "production" on Render.
# FRONTEND_URL=                  # Public URL of the Vercel frontend, e.g. https://wisp.vercel.app
# BACKEND_URL=                   # Public URL of this Render service, used for OAuth callback.
# REDIS_URL=                     # Defaults to redis://localhost:6379 in dev. Required in prod for socket scaling, rate limiting, presence.
#
# Google OAuth (sign-in with Google). If unset, /api/auth/oauth returns 503.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# Cloudinary (image uploads). Uploads fail at use site if any are unset.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# Gemini (AI assistant). Falls back to GOOGLE_API_KEY if GEMINI_API_KEY is unset.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
